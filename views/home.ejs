<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Let's Game About It</title>

  <link rel="stylesheet" href="/css/output.css">
</head>

<body class="bg-zinc-950 text-white">

  <%- include("partials/navBar") %>

  <main class="min-h-screen">

    <section class="max-w-7xl mx-auto px-8 py-20">

      <div class="max-w-3xl">

        <span class="text-violet-400 font-semibold">
          Bem-vindo ao Let's Game About It
        </span>

        <h1 class="text-6xl font-black mt-4 leading-tight">
          Compartilhe suas
          <span class="text-violet-500">
            opiniões
          </span>
          sobre os melhores jogos
        </h1>

        <p class="text-zinc-400 text-lg mt-6">
          Descubra novos títulos, publique reviews,
          participe de comunidades e acompanhe os jogos
          mais comentados do momento.
        </p>

        <div class="flex gap-4 mt-8">

          <a
            href="/games"
            class="px-6 py-3 bg-violet-600 rounded-xl hover:bg-violet-700 transition"
          >
            Explorar Jogos
          </a>

          <a
            href="/reviews"
            class="px-6 py-3 border border-zinc-700 rounded-xl hover:border-violet-500 transition"
          >
            Ver Reviews
          </a>

        </div>

      </div>

    </section>

  </main>

  <%- include("partials/footer") %>

</body>
</html>