<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cadastro - Let's Game About It</title>

  <link rel="stylesheet" href="/css/output.css">
</head>

<body class="bg-zinc-950 min-h-screen flex">

  <!-- Lado esquerdo -->
  <div class="hidden lg:flex w-1/2 bg-gradient-to-br from-purple-900 via-zinc-900 to-black items-center justify-center p-12">

    <div class="max-w-lg">

      <h1 class="text-6xl font-bold text-white mb-6">
        🎮 Let's Game About It
      </h1>

      <p class="text-zinc-300 text-xl leading-relaxed">
        Descubra novos jogos, compartilhe opiniões,
        publique reviews e encontre outros jogadores
        apaixonados pelo universo gamer.
      </p>

      <div class="grid grid-cols-2 gap-4 mt-10">

        <div class="bg-zinc-800/60 p-4 rounded-xl">
          <h3 class="text-purple-400 font-bold text-lg">
            Reviews
          </h3>
          <p class="text-zinc-400">
            Avalie seus jogos favoritos
          </p>
        </div>

        <div class="bg-zinc-800/60 p-4 rounded-xl">
          <h3 class="text-purple-400 font-bold text-lg">
            Comunidade
          </h3>
          <p class="text-zinc-400">
            Compartilhe experiências
          </p>
        </div>

        <div class="bg-zinc-800/60 p-4 rounded-xl">
          <h3 class="text-purple-400 font-bold text-lg">
            Rankings
          </h3>
          <p class="text-zinc-400">
            Veja os jogos mais amados
          </p>
        </div>

        <div class="bg-zinc-800/60 p-4 rounded-xl">
          <h3 class="text-purple-400 font-bold text-lg">
            Descobertas
          </h3>
          <p class="text-zinc-400">
            Encontre novos títulos
          </p>
        </div>

      </div>

    </div>

  </div>

  <!-- Lado direito -->
  <div class="w-full lg:w-1/2 flex items-center justify-center px-6">

    <div class="w-full max-w-md">

      <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

        <h2 class="text-4xl font-bold text-white mb-2">
          Criar Conta
        </h2>

        <p class="text-zinc-400 mb-8">
          Entre para a comunidade gamer
        </p>

        <form action="/register" method="POST" class="space-y-5">

          <div>
            <label class="block text-zinc-300 mb-2">
              Usuário
            </label>

            <input
              type="text"
              name="username"
              placeholder="Digite seu usuário"
              required
              class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500"
            >
          </div>

          <div>
            <label class="block text-zinc-300 mb-2">
              Email
            </label>

            <input
              type="email"
              name="email"
              placeholder="Digite seu email"
              required
              class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500"
            >
          </div>

          <div>
            <label class="block text-zinc-300 mb-2">
              Senha
            </label>

            <input
              type="password"
              name="password"
              placeholder="Digite sua senha"
              required
              class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white focus:outline-none focus:border-purple-500"
            >
          </div>

          <button
            type="submit"
            class="w-full bg-purple-600 hover:bg-purple-700 transition duration-300 text-white py-3 rounded-xl font-semibold"
          >
            Criar Conta
          </button>

        </form>

        <div class="mt-6 text-center">

          <p class="text-zinc-400">
            Já possui uma conta?

            <a
              href="/login"
              class="text-purple-400 hover:text-purple-300 font-medium"
            >
              Entrar
            </a>

          </p>

        </div>

      </div>

    </div>

  </div>

</body>
</html>