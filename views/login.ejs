<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Login - Let's Game About It</title>

  <link rel="stylesheet" href="/css/output.css">
</head>

<body class="bg-zinc-950 min-h-screen flex">

  <div class="hidden lg:flex w-1/2 bg-gradient-to-br from-purple-900 via-zinc-900 to-black items-center justify-center p-12">

    <div>

      <h1 class="text-6xl font-bold text-white mb-6">
        🎮 Let's Game About It
      </h1>

      <p class="text-zinc-300 text-xl">
        Continue sua jornada gamer e descubra novas reviews.
      </p>

    </div>

  </div>

  <div class="w-full lg:w-1/2 flex items-center justify-center px-6">

    <div class="w-full max-w-md bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-2xl">

      <h2 class="text-4xl font-bold text-white mb-2">
        Entrar
      </h2>

      <p class="text-zinc-400 mb-8">
        Bem-vindo de volta
      </p>

      <form action="/login" method="POST" class="space-y-5">

        <input
          type="email"
          name="email"
          placeholder="Email"
          class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white"
          required
        >

        <input
          type="password"
          name="password"
          placeholder="Senha"
          class="w-full bg-zinc-800 border border-zinc-700 rounded-xl px-4 py-3 text-white"
          required
        >

        <button
          class="w-full bg-purple-600 hover:bg-purple-700 text-white py-3 rounded-xl font-semibold transition"
        >
          Entrar
        </button>

      </form>

      <p class="text-center text-zinc-400 mt-6">
        Não possui conta?

        <a
          href="/register"
          class="text-purple-400"
        >
          Cadastre-se
        </a>

      </p>

    </div>

  </div>

</body>
</html>