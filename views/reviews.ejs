<!DOCTYPE html>
<html lang="pt-BR">

<head>

  <meta charset="UTF-8">

  <title>Reviews da Comunidade</title>

  <link rel="stylesheet" href="/css/output.css">

</head>

<body class="bg-zinc-950 text-white min-h-screen flex flex-col">

  <%- include("partials/navBar") %>

  <main class="flex-1">

    <div class="max-w-7xl mx-auto px-6 py-12">

      <!-- Título -->

      <h1 class="text-6xl font-black mb-4">
        Reviews da Comunidade
      </h1>

      <p class="text-zinc-400 text-xl mb-12">
        Veja o que a comunidade está jogando e opinando.
      </p>

      <% if(reviews.length === 0) { %>

        <div class="bg-zinc-900 p-8 rounded-3xl border border-zinc-800">

          Nenhuma review publicada ainda.

        </div>

      <% } %>

      <% reviews.forEach(review => { %>

        <div
          class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 mb-8 hover:border-violet-500 hover:scale-[1.01] transition duration-300"
        >

          <div class="flex flex-col lg:flex-row gap-6">

            <!-- Capa -->

            <img
              src="<%= review.gameImage %>"
              alt="<%= review.gameName %>"
              class="w-full lg:w-52 h-72 object-cover rounded-2xl"
            >

            <!-- Conteúdo -->

            <div class="flex-1 flex flex-col justify-between">

              <div>

                <!-- Usuário -->

                <div class="flex items-center gap-4 mb-6">

                  <div
                    class="w-14 h-14 rounded-full bg-violet-600 flex items-center justify-center text-xl"
                  >
                    🎮
                  </div>

                  <div>

                    <h3 class="font-bold text-2xl">
                      <%= review.user.username %>
                    </h3>

                    <p class="text-zinc-500">
                      Review da comunidade
                    </p>

                  </div>

                </div>

                <!-- Nome do jogo -->

                <h2 class="text-4xl font-black mb-4">
                  <%= review.gameName %>
                </h2>

                <!-- Nota -->

                <div class="text-yellow-400 text-3xl mb-6">

                  <%= "★".repeat(review.rating) %>

                </div>

                <!-- Comentário -->

                <p
                  class="text-zinc-300 text-lg leading-relaxed max-w-3xl"
                >
                  <%= review.content %>
                </p>

              </div>

            </div>

          </div>

        </div>

      <% }) %>

    </div>

  </main>

  <%- include("partials/footer") %>

</body>

</html>